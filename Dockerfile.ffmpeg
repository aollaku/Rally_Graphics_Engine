FROM node:20-alpine

RUN apk add --no-cache \
    bash \
    ffmpeg \
    chromium \
    xvfb \
    ttf-freefont \
    font-noto \
    mesa-dri-gallium

ENV CHROME_BIN=/usr/bin/chromium-browser
ENV FFMPEG_PATH=/usr/bin/ffmpeg
ENV PORT=3100
WORKDIR /engine
COPY ffmpeg-engine/server.js ./server.js
COPY scripts ./scripts
RUN chmod +x /engine/scripts/*.sh || true
EXPOSE 3100
CMD ["node", "server.js"]
